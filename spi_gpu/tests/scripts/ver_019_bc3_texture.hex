# VER-019: BC3 Texture Golden Image Test
# 
# 256x256 BC3-compressed Skyline texture on a 512x480 quad.
# Tests BC3 interpolated alpha + BC1 color decode.

## FRAMEBUFFER: 512 480
## PHASE: main

# Clear color buffer: base_word=0x000000 value=0x0000 count=262144
44 0400_0000_0000_0000  # MEM_FILL: base_word=0x000000 value=0x0000 count=262144

## INCLUDE: textures/skyline_256x256_bc3.hex

40 0000_0099_0000_0000  # FB_CONFIG: color_base=0x0000 z_base=0x0000 w_log2=9 h_log2=9
43 0000_0078_2000_0000  # FB_CONTROL: scissor x=0 y=0 w=512 h=480
10 0000_0800_0000_8821  # TEX0_CFG: ENABLE=1 NEAREST BC3 256x256 REPEAT base=0x0800
18 7670_7670_7371_7371  # CC_MODE: MODULATE: cycle0=TEX0*SHADE0 cycle1=COMBINED*ONE
30 0000_0000_0000_0010  # RENDER_MODE: COLOR_WRITE_EN

00 FFFF_FFFF_0000_00FF  # COLOR: diffuse=white specular=black
01 0000_0000_0000_0000  # ST0_ST1: s0=0 t0=0
06 8000_0000_0000_0000  # VERTEX_NOKICK: x=0 y=0 z=0x0000

00 FFFF_FFFF_0000_00FF  # COLOR: diffuse=white specular=black
01 0000_0000_0000_1000  # ST0_ST1: s0=1 t0=0
06 8000_0000_0000_2000  # VERTEX_NOKICK: x=512 y=0 z=0x0000

00 FFFF_FFFF_0000_00FF  # COLOR: diffuse=white specular=black
01 0000_0000_1000_1000  # ST0_ST1: s0=1 t0=1
07 8000_0000_1E00_2000  # VERTEX_KICK_012: x=512 y=480 z=0x0000

00 FFFF_FFFF_0000_00FF  # COLOR: diffuse=white specular=black
01 0000_0000_0000_0000  # ST0_ST1: s0=0 t0=0
06 8000_0000_0000_0000  # VERTEX_NOKICK: x=0 y=0 z=0x0000

00 FFFF_FFFF_0000_00FF  # COLOR: diffuse=white specular=black
01 0000_0000_1000_1000  # ST0_ST1: s0=1 t0=1
06 8000_0000_1E00_2000  # VERTEX_NOKICK: x=512 y=480 z=0x0000

00 FFFF_FFFF_0000_00FF  # COLOR: diffuse=white specular=black
01 0000_0000_1000_0000  # ST0_ST1: s0=0 t0=1
07 8000_0000_1E00_0000  # VERTEX_KICK_012: x=0 y=480 z=0x0000

