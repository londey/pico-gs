43 0000_0080_2000_0000  # FB_CONTROL: scissor x=0 y=0 w=512 h=512
10 0000_0C00_0000_6645  # TEX0_CFG: ENABLE=1 BILINEAR RGB565 64x64 REPEAT base=0x0C00
