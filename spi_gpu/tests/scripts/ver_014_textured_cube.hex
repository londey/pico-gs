# VER-014: Textured Cube Golden Image Test
# 
# 12-triangle cube with depth testing and checker texture.
# Phase 'zclear': initialize Z-buffer to 0xFFFF
# Phase 'setup': configure texture and render mode
# Phase 'triangles': submit 12 cube triangles

## FRAMEBUFFER: 512 512
## TEXTURE: checker_wb base=0x80000 format=RGB565 width_log2=4

## PHASE: zclear

44 0004_0000_FFFF_0800  # MEM_FILL: base=0x0800 value=0xFFFF count=262144
40 0000_0099_0800_0000  # FB_CONFIG: color_base=0x0000 z_base=0x0800 w_log2=9 h_log2=9
43 0000_0080_2000_0000  # FB_CONTROL: scissor x=0 y=0 w=512 h=512

## PHASE: setup

40 0000_0099_0800_0000  # FB_CONFIG: color_base=0x0000 z_base=0x0800 w_log2=9 h_log2=9
43 0000_0080_2000_0000  # FB_CONTROL: scissor x=0 y=0 w=512 h=512
10 0000_0800_0000_4441  # TEX0_CFG: ENABLE=1 NEAREST RGB565 16x16 REPEAT base=0x0800
30 0000_0000_0000_201D  # RENDER_MODE: GOURAUD_EN | Z_TEST_EN | Z_WRITE_EN | COLOR_WRITE_EN | Z_COMPARE=LEQUAL

00 0000_0000_0000_0000  # COLOR: dummy NOP (FIFO FWFT workaround)

