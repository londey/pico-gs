# VER-011: Depth-Tested Overlapping Triangles
# 
# Phase 'zclear': initialize Z-buffer to 0x0000 (reverse-Z)
# Phase 'tri_a': red triangle at Z=0x4000 (far)
# Phase 'tri_b': blue triangle at Z=0x8000 (near, occludes A)

## FRAMEBUFFER: 512 480

## PHASE: zclear

# Clear color buffer: base_word=0x000000 value=0x0000 count=262144
44 0400_0000_0000_0000  # MEM_FILL: base_word=0x000000 value=0x0000 count=262144

44 0400_0000_0008_0000  # MEM_FILL: base_word=0x080000 value=0x0000 count=262144
40 0000_0099_0800_0000  # FB_CONFIG: color_base=0x0000 z_base=0x0800 w_log2=9 h_log2=9
43 0000_0078_2000_0000  # FB_CONTROL: scissor x=0 y=0 w=512 h=480
18 7670_7670_7673_7673  # CC_MODE: SHADE_PASSTHROUGH: cycle0=SHADE0*ONE cycle1=COMBINED*ONE

## PHASE: tri_a

30 0000_0000_0000_601D  # RENDER_MODE: GOURAUD_EN | Z_TEST_EN | Z_WRITE_EN | COLOR_WRITE_EN | Z_COMPARE=GEQUAL

00 FF00_00FF_0000_00FF  # COLOR: diffuse=red specular=black
06 0000_4000_0640_0500  # VERTEX_NOKICK: x=80 y=100 z=0x4000
00 FF00_00FF_0000_00FF  # COLOR: diffuse=red specular=black
06 0000_4000_0640_1400  # VERTEX_NOKICK: x=320 y=100 z=0x4000
00 FF00_00FF_0000_00FF  # COLOR: diffuse=red specular=black
07 0000_4000_17C0_0C80  # VERTEX_KICK_012: x=200 y=380 z=0x4000


## PHASE: tri_b

00 0000_FFFF_0000_00FF  # COLOR: diffuse=blue specular=black
06 0000_8000_0500_0A00  # VERTEX_NOKICK: x=160 y=80 z=0x8000
00 0000_FFFF_0000_00FF  # COLOR: diffuse=blue specular=black
06 0000_8000_0500_1900  # VERTEX_NOKICK: x=400 y=80 z=0x8000
00 0000_FFFF_0000_00FF  # COLOR: diffuse=blue specular=black
07 0000_8000_1680_1180  # VERTEX_KICK_012: x=280 y=360 z=0x8000

