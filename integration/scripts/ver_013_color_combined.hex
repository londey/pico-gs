# VER-013: Color-Combined Output Golden Image Test (INDEXED8_2X2)
# 
# Textured triangle with MODULATE combiner (TEX0 * SHADE0).
# 16x16 apparent INDEXED8_2X2; palette entry 0 quadrants
# encode a white/mid-grey checker via the 2x2 quadrant lookup.

## FRAMEBUFFER: 512 512
## PHASE: palette

# Clear color buffer: base_word=0x000000 value=0x0000 count=262144
44 0400_0000_0000_0000  # MEM_FILL: base_word=0x000000 value=0x0000 count=262144

# Upload PALETTE0 blob (4096 B, 1 populated entries) at byte 0x110000.
44 0008_0000_0008_8000  # MEM_FILL: base_word=0x088000 value=0x0000 count=2048
70 0000_0000_0002_2000  # MEM_ADDR: dword_addr=0x22000
71 FF80_8080_FFFF_FFFF  # MEM_DATA: palette dword[0]
71 FFFF_FFFF_FF80_8080  # MEM_DATA: palette dword[1]
12 0000_0000_0001_0880  # PALETTE0: BASE_ADDR=0x0880 LOAD_TRIGGER=1

# Upload all-zero index blocks (4×16 B) (64 B) at word 0x80000.
70 0000_0000_0002_0000  # MEM_ADDR: dword_addr=0x20000
71 0000_0000_0000_0000  # MEM_DATA: index dword[0]
71 0000_0000_0000_0000  # MEM_DATA: index dword[1]
71 0000_0000_0000_0000  # MEM_DATA: index dword[2]
71 0000_0000_0000_0000  # MEM_DATA: index dword[3]
71 0000_0000_0000_0000  # MEM_DATA: index dword[4]
71 0000_0000_0000_0000  # MEM_DATA: index dword[5]
71 0000_0000_0000_0000  # MEM_DATA: index dword[6]
71 0000_0000_0000_0000  # MEM_DATA: index dword[7]

## PHASE: main

40 0000_0099_0000_0000  # FB_CONFIG: color_base=0x0000 z_base=0x0000 w_log2=9 h_log2=9
43 0000_0080_2000_0000  # FB_CONTROL: scissor x=0 y=0 w=512 h=512
10 0000_0800_0000_4401  # TEX0_CFG: ENABLE=1 NEAREST INDEXED8_2X2 16x16 REPEAT PALETTE_IDX=0 base=0x0800
18 7670_7670_7371_7371  # CC_MODE: MODULATE: cycle0=TEX0*SHADE0 cycle1=COMBINED*ONE
30 0000_0000_0000_0011  # RENDER_MODE: GOURAUD_EN | COLOR_WRITE_EN

00 FF00_00FF_0000_00FF  # COLOR: diffuse=red specular=black
01 0000_0000_0000_0800  # ST0_ST1: s0=0.5 t0=0
06 8000_0000_03C0_1400  # VERTEX_NOKICK: x=320 y=60 z=0x0000

00 0000_FFFF_0000_00FF  # COLOR: diffuse=blue specular=black
01 0000_0000_1000_1000  # ST0_ST1: s0=1 t0=1
06 8000_0000_17C0_1FF0  # VERTEX_NOKICK: x=511 y=380 z=0x0000

00 00FF_00FF_0000_00FF  # COLOR: diffuse=green specular=black
01 0000_0000_1000_0000  # ST0_ST1: s0=0 t0=1
07 8000_0000_17C0_0640  # VERTEX_KICK_012: x=100 y=380 z=0x0000

## PHASE: flush

45 0000_0000_0000_0001  # FB_CACHE_CTRL: FLUSH_TRIGGER
