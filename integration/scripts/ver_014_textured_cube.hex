43 0000_0080_2000_0000  # FB_CONTROL: scissor x=0 y=0 w=512 h=512
10 0000_0C00_0000_4401  # TEX0_CFG: ENABLE=1 NEAREST INDEXED8_2X2 16x16 REPEAT PALETTE_IDX=0 base=0x0C00
