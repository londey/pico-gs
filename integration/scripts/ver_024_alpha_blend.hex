# VER-024: Alpha Blend Modes
# 
# 256x256 framebuffer.  Background is a 4x4 dark/light grey
# checkerboard.  Each quadrant draws a red triangle with two
# opaque top vertices and one transparent bottom vertex.
# CC pass 0 pre-multiplies RGB by SHADE0_ALPHA so the color
# itself fades along with the interpolated alpha.
# 
# CC passes 0 and 1 are plain pass-through; all alpha modulation
# happens in pass 2 via CC_MODE_2.
# 
# Quadrants:
#   Top-left     (0,0):     CC2_PREMUL_OVERWRITE -- src*alpha overwrites dst
#   Top-right    (128,0):   CC2_ADD              -- src*alpha + dst
#   Bottom-left  (0,128):   CC2_SUBTRACT         -- dst - src*alpha
#   Bottom-right (128,128): CC2_BLEND            -- Porter-Duff src-over
# 
# Each phase programs CC_MODE_2 directly; the pixel pipeline
# decodes the selectors to decide whether to fetch DST_COLOR.

## FRAMEBUFFER: 256 256

## PHASE: clear

# Clear color buffer: base_word=0x000000 value=0x0000 count=65536
44 0100_0000_0000_0000  # MEM_FILL: base_word=0x000000 value=0x0000 count=65536
40 0000_0088_0000_0000  # FB_CONFIG: color_base=0 w_log2=8 h_log2=8
43 0000_0040_1000_0000  # FB_CONTROL: scissor x=0 y=0 w=256 h=256
18 7670_7670_7673_7673  # CC_MODE: SHADE_PASSTHROUGH: pass 0 and 1 forward SHADE0 unchanged

## PHASE: checkerboard

30 0000_0000_0000_0011  # RENDER_MODE: GOURAUD_EN | COLOR_WRITE_EN

# Fill background with dark grey (two covering triangles)
00 5555_55FF_0000_0000  # COLOR: diffuse=(85,85,85,255) specular=zero
06 0000_0000_0000_0000  # VERTEX_NOKICK: x=0 y=0 z=0x0000
06 0000_0000_0000_1000  # VERTEX_NOKICK: x=256 y=0 z=0x0000
07 0000_0000_1000_1000  # VERTEX_KICK_012: x=256 y=256 z=0x0000
06 0000_0000_0000_0000  # VERTEX_NOKICK: x=0 y=0 z=0x0000
06 0000_0000_1000_1000  # VERTEX_NOKICK: x=256 y=256 z=0x0000
07 0000_0000_1000_0000  # VERTEX_KICK_012: x=0 y=256 z=0x0000

# Light grey 64x64 tiles forming the checkerboard
00 B0B0_B0FF_0000_0000  # COLOR: diffuse=(176,176,176,255) specular=zero
06 0000_0000_0000_0000  # VERTEX_NOKICK: x=0 y=0 z=0x0000
06 0000_0000_0000_0400  # VERTEX_NOKICK: x=64 y=0 z=0x0000
07 0000_0000_0400_0400  # VERTEX_KICK_012: x=64 y=64 z=0x0000
06 0000_0000_0000_0000  # VERTEX_NOKICK: x=0 y=0 z=0x0000
06 0000_0000_0400_0400  # VERTEX_NOKICK: x=64 y=64 z=0x0000
07 0000_0000_0400_0000  # VERTEX_KICK_012: x=0 y=64 z=0x0000
06 0000_0000_0000_0800  # VERTEX_NOKICK: x=128 y=0 z=0x0000
06 0000_0000_0000_0C00  # VERTEX_NOKICK: x=192 y=0 z=0x0000
07 0000_0000_0400_0C00  # VERTEX_KICK_012: x=192 y=64 z=0x0000
06 0000_0000_0000_0800  # VERTEX_NOKICK: x=128 y=0 z=0x0000
06 0000_0000_0400_0C00  # VERTEX_NOKICK: x=192 y=64 z=0x0000
07 0000_0000_0400_0800  # VERTEX_KICK_012: x=128 y=64 z=0x0000
06 0000_0000_0400_0400  # VERTEX_NOKICK: x=64 y=64 z=0x0000
06 0000_0000_0400_0800  # VERTEX_NOKICK: x=128 y=64 z=0x0000
07 0000_0000_0800_0800  # VERTEX_KICK_012: x=128 y=128 z=0x0000
06 0000_0000_0400_0400  # VERTEX_NOKICK: x=64 y=64 z=0x0000
06 0000_0000_0800_0800  # VERTEX_NOKICK: x=128 y=128 z=0x0000
07 0000_0000_0800_0400  # VERTEX_KICK_012: x=64 y=128 z=0x0000
06 0000_0000_0400_0C00  # VERTEX_NOKICK: x=192 y=64 z=0x0000
06 0000_0000_0400_1000  # VERTEX_NOKICK: x=256 y=64 z=0x0000
07 0000_0000_0800_1000  # VERTEX_KICK_012: x=256 y=128 z=0x0000
06 0000_0000_0400_0C00  # VERTEX_NOKICK: x=192 y=64 z=0x0000
06 0000_0000_0800_1000  # VERTEX_NOKICK: x=256 y=128 z=0x0000
07 0000_0000_0800_0C00  # VERTEX_KICK_012: x=192 y=128 z=0x0000
06 0000_0000_0800_0000  # VERTEX_NOKICK: x=0 y=128 z=0x0000
06 0000_0000_0800_0400  # VERTEX_NOKICK: x=64 y=128 z=0x0000
07 0000_0000_0C00_0400  # VERTEX_KICK_012: x=64 y=192 z=0x0000
06 0000_0000_0800_0000  # VERTEX_NOKICK: x=0 y=128 z=0x0000
06 0000_0000_0C00_0400  # VERTEX_NOKICK: x=64 y=192 z=0x0000
07 0000_0000_0C00_0000  # VERTEX_KICK_012: x=0 y=192 z=0x0000
06 0000_0000_0800_0800  # VERTEX_NOKICK: x=128 y=128 z=0x0000
06 0000_0000_0800_0C00  # VERTEX_NOKICK: x=192 y=128 z=0x0000
07 0000_0000_0C00_0C00  # VERTEX_KICK_012: x=192 y=192 z=0x0000
06 0000_0000_0800_0800  # VERTEX_NOKICK: x=128 y=128 z=0x0000
06 0000_0000_0C00_0C00  # VERTEX_NOKICK: x=192 y=192 z=0x0000
07 0000_0000_0C00_0800  # VERTEX_KICK_012: x=128 y=192 z=0x0000
06 0000_0000_0C00_0400  # VERTEX_NOKICK: x=64 y=192 z=0x0000
06 0000_0000_0C00_0800  # VERTEX_NOKICK: x=128 y=192 z=0x0000
07 0000_0000_1000_0800  # VERTEX_KICK_012: x=128 y=256 z=0x0000
06 0000_0000_0C00_0400  # VERTEX_NOKICK: x=64 y=192 z=0x0000
06 0000_0000_1000_0800  # VERTEX_NOKICK: x=128 y=256 z=0x0000
07 0000_0000_1000_0400  # VERTEX_KICK_012: x=64 y=256 z=0x0000
06 0000_0000_0C00_0C00  # VERTEX_NOKICK: x=192 y=192 z=0x0000
06 0000_0000_0C00_1000  # VERTEX_NOKICK: x=256 y=192 z=0x0000
07 0000_0000_1000_1000  # VERTEX_KICK_012: x=256 y=256 z=0x0000
06 0000_0000_0C00_0C00  # VERTEX_NOKICK: x=192 y=192 z=0x0000
06 0000_0000_1000_1000  # VERTEX_NOKICK: x=256 y=256 z=0x0000
07 0000_0000_1000_0C00  # VERTEX_KICK_012: x=192 y=256 z=0x0000

## PHASE: blend_disabled

1A 0000_0000_7670_7C70  # CC_MODE_2: PREMUL_OVERWRITE: (COMBINED-ZERO)*COMBINED_ALPHA + ZERO
30 0000_0000_0000_0011  # RENDER_MODE: GOURAUD_EN | COLOR_WRITE_EN
# PREMUL_OVERWRITE: src*alpha overwrites destination.
00 FF00_00FF_0000_0000  # COLOR: diffuse=red specular=zero
06 0000_0000_00C0_00C0  # VERTEX_NOKICK: x=12 y=12 z=0x0000
06 0000_0000_00C0_0740  # VERTEX_NOKICK: x=116 y=12 z=0x0000
00 FF00_0000_0000_0000  # COLOR: diffuse=black(A=0) specular=zero
07 0000_0000_0740_0400  # VERTEX_KICK_012: x=64 y=116 z=0x0000

## PHASE: blend_add

1A 0000_0000_7670_9C70  # CC_MODE_2: ADD: (COMBINED-ZERO)*COMBINED_ALPHA + DST_COLOR
30 0000_0000_0000_0011  # RENDER_MODE: GOURAUD_EN | COLOR_WRITE_EN
# ADD: dst + src*alpha.
00 FF00_00FF_0000_0000  # COLOR: diffuse=red specular=zero
06 0000_0000_00C0_08C0  # VERTEX_NOKICK: x=140 y=12 z=0x0000
06 0000_0000_00C0_0F40  # VERTEX_NOKICK: x=244 y=12 z=0x0000
00 FF00_0000_0000_0000  # COLOR: diffuse=black(A=0) specular=zero
07 0000_0000_0740_0C00  # VERTEX_KICK_012: x=192 y=116 z=0x0000

## PHASE: blend_subtract

1A 0000_0000_7670_9C07  # CC_MODE_2: SUBTRACT: (ZERO-COMBINED)*COMBINED_ALPHA + DST_COLOR
30 0000_0000_0000_0011  # RENDER_MODE: GOURAUD_EN | COLOR_WRITE_EN
# SUBTRACT: dst - src*alpha.
00 FF00_00FF_0000_0000  # COLOR: diffuse=red specular=zero
06 0000_0000_08C0_00C0  # VERTEX_NOKICK: x=12 y=140 z=0x0000
06 0000_0000_08C0_0740  # VERTEX_NOKICK: x=116 y=140 z=0x0000
00 FF00_0000_0000_0000  # COLOR: diffuse=black(A=0) specular=zero
07 0000_0000_0F40_0400  # VERTEX_KICK_012: x=64 y=244 z=0x0000

## PHASE: blend_porter_duff

1A 0000_0000_7670_9C90  # CC_MODE_2: BLEND: (COMBINED-DST_COLOR)*COMBINED_ALPHA + DST_COLOR
30 0000_0000_0000_0011  # RENDER_MODE: GOURAUD_EN | COLOR_WRITE_EN
# BLEND: src*alpha + dst*(1-alpha) (Porter-Duff source-over).
00 FF00_00FF_0000_0000  # COLOR: diffuse=red specular=zero
06 0000_0000_08C0_08C0  # VERTEX_NOKICK: x=140 y=140 z=0x0000
06 0000_0000_08C0_0F40  # VERTEX_NOKICK: x=244 y=140 z=0x0000
00 FF00_0000_0000_0000  # COLOR: diffuse=black(A=0) specular=zero
07 0000_0000_0F40_0C00  # VERTEX_KICK_012: x=192 y=244 z=0x0000
